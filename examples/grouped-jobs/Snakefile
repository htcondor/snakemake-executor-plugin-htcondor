rule all:
    input: "results/final_results.txt"

# Layer 1: Single job
rule prepare:
    input: "inputs/raw.txt"
    output: "results/prepared.txt"  # This output is shared by all analyze_* rules
    group: "my_group"
    resources:
        htcondor_request_mem_mb=2048,
        htcondor_request_disk_mb=4096
    shell: "cat {input} | sed 's/raw/prepared/' > {output}"

# Layer 2: Three jobs run in PARALLEL
## Branch A
rule analyze_part_a:
    input: "results/prepared.txt"   # Same input
    output: "results/part_a.txt"  # Different output
    group: "my_group"
    resources:
        htcondor_request_mem_mb=4096,
        htcondor_request_disk_mb=2048
    shell: "cat {input} | sed 's/prepared/analyzed_a/' > {output}"
## Branch B
rule analyze_part_b:
    input: "results/prepared.txt"   # Same input
    output: "results/part_b.txt"  # Different output
    group: "my_group"
    resources:
        htcondor_request_mem_mb=4096,
        htcondor_request_disk_mb=2048
    shell: "cat {input} | sed 's/prepared/analyzed_b/' > {output}"
## Branch C
rule analyze_part_c:
    input: "results/prepared.txt"   # Same input
    output: "results/part_c.txt"  # Different output
    group: "my_group"
    resources:
        htcondor_request_mem_mb=4096,
        htcondor_request_disk_mb=2048
    shell: "cat {input} | sed 's/prepared/analyzed_c/' > {output}"

# Layer 3: Combine results
rule combine:
    input: "results/part_a.txt", "results/part_b.txt", "results/part_c.txt"
    output: "results/final_results.txt"
    group: "my_group"
    resources:
        htcondor_request_mem_mb=2048,
        htcondor_request_disk_mb=4096
    shell: "for f in {input}; do cat $f; echo; done > {output}"
